RBA_SQL_ENDPOINT=https://iam.rbaelevadores.com.br/retornasqljson
RBA_AUTH_SECRET=troque-por-uma-chave-grande-e-aleatoria
# Opcional, caso o endpoint passe a exigir token no futuro:
# RBA_SQL_TOKEN=
# Compatibilidade com abertura antiga do app Flutter usando ?codusuario=123.
# Mantenha false se não for necessário.
RBA_ALLOW_LEGACY_DIRECT_LOGIN=false
